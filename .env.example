TELEGRAM_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
JWT_SECRET=your_jwt_secret_here_min_32_chars
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_BASE_URL=https://api.openai.com/v1

# Supabase — Project Settings > Database > URI (add ?sslmode=require)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require

# Redis — optional, omit to use in-memory fallback (fine for single-instance free tier)
# REDIS_URL=redis://localhost:6379

TELEGRAM_GROUP_CHAT_ID=-1001234567890
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
OWNER_TELEGRAM_ID=your_telegram_user_id_here
NEWS_API_KEY=your_newsapi_key_here
APPROVAL_TTL_SECONDS=3600
MAX_HISTORY=50
MAX_RETRIES=3

# Git deployer (for /bot coding push-to-deploy)
# Use a token-embedded URL so the container can push back to GitHub
GIT_REMOTE=https://<github-token>@github.com/<user>/<repo>.git
GIT_BRANCH=main
REPO_ROOT=/app
# Optional: Render manual deploy hook (not needed — Render auto-deploys on push)
DEPLOY_HOOK_URL=
